<?xml version="1.0" encoding="utf-8" ?>
<odoo>

<record id="view_picking_form_inherit_internal_transfer" model="ir.ui.view">
    <field name="name">stock.picking.form.inherit.internal.transfer</field>
    <field name="model">stock.picking</field>
    <field name="inherit_id" ref="stock.view_picking_form"/>
    <field name="arch" type="xml">
        <!-- Add invisible helper field -->
        <xpath expr="//field[@name='location_id']" position="before">
            <field name="location_id_domain_ids" invisible="1"/>
        </xpath>

        <!-- Modify domain -->
        <xpath expr="//field[@name='location_id'][2]" position="attributes">
            <attribute name="domain">[('id', 'in', location_id_domain_ids)]</attribute>
        </xpath>
    </field>
</record>
</odoo>