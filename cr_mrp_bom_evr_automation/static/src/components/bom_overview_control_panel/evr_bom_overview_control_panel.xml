<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!--
        Extends the BOM overview control panel to add the "Run Purchase Flow" button
        after the Fold/Unfold button. Only visible for EVR BOMs (checked server-side).
    -->
    <t t-inherit="mrp.BomOverviewControlPanel" t-inherit-mode="extension">
        <xpath expr="//button[@t-on-click='clickTogglefold']" position="after">
            <button t-on-click="runPurchaseFlow"
                    type="button"
                    class="btn btn-primary ms-1">
                Run Purchase Flow
            </button>
        </xpath>

        <xpath expr="//div[Dropdown[@items='warehousesItems']]" position="replace"/>
    </t>
</templates>
