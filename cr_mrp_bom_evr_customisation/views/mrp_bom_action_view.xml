<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_force_sync_bom_usage" model="ir.actions.server">
        <field name="name">Force Sync BOM Usage Strings</field>
        <field name="model_id" ref="mrp.model_mrp_bom"/>
        <field name="binding_model_id" ref="mrp.model_mrp_bom"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
for bom in records:
    if bom.is_evr and bom.project_id:
        bom.with_context(skip_branch_recompute=False)._assign_branches_for_bom()
        </field>
    </record>
</odoo>
