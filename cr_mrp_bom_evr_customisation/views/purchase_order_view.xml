<odoo>
    <record id="view_purchase_order_form_inherit_cfe" model="ir.ui.view">
        <field name="name">purchase.order.form.cfe.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <!-- Insert after Vendor Reference -->
            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="cfe"/>
            </xpath>

            <!-- Update Order Line Tree View -->
            <xpath expr="//field[@name='order_line']/list//field[@name='product_id']" position="after">
                <field name="branch_id" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/list//field[@name='analytic_distribution']" position="replace">
                <field name="distribution_analytic_account_ids" widget="many2many_tags" groups="analytic.group_analytic_accounting" optional="show"/>
            </xpath>

        </field>
    </record>
</odoo>
