<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View for Mechanical Parts Management -->
    <record id="view_mrp_mechanical_part_tree" model="ir.ui.view">
        <field name="name">mrp.mechanical.part.tree</field>
        <field name="model">mrp.mechanical.part</field>
        <field name="arch" type="xml">
            <list string="Mechanical Parts" editable="bottom" create="0" delete="0">
                <field name="project_name" readonly="1"/>
                <field name="root_product_code" readonly="1"/>
                <field name="bom_line_id" readonly="1" string="Product"/>
                <field name="mo_ids" widget="many2many_tags" readonly="1"/>
                <field name="all_mos_draft" invisible="1"/>
                <field name="is_buy_make_product" invisible="1"/>
                <field name="buy_make_selection" 
                       widget="selection" 
                       required="1"
                       readonly="not is_buy_make_product"/>
            </list>
        </field>
    </record>

    <!-- Action for Mechanical Parts -->
    <record id="action_mrp_mechanical_parts" model="ir.actions.act_window">
        <field name="name">Mechanical parts</field>
        <field name="res_model">mrp.mechanical.part</field>
        <field name="view_mode">list</field>
        <field name="domain">[('all_mos_draft', '=', True), '|', ('part_type', '=', 'branch'), '&amp;', ('part_type', '=', 'component'), ('buy_make_selection', '!=', False)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No mechanical parts to manage.
            </p>
            <p>
                This view shows parts where all associated Manufacturing Orders are in Draft state.
            </p>
        </field>
    </record>

    <!-- Menu Item for Mechanical Parts -->
    <menuitem id="menu_mrp_mechanical_parts"
              name="Mechanical parts"
              parent="mrp.menu_mrp_reporting"
              action="action_mrp_mechanical_parts"
              sequence="25"/>
    <!-- Server Action to Force Sync Mechanical Parts for selected BoMs -->
    <record id="action_server_sync_mechanical_parts" model="ir.actions.server">
        <field name="name">Sync Mechanical Parts</field>
        <field name="model_id" ref="mrp.model_mrp_bom"/>
        <field name="binding_model_id" ref="mrp.model_mrp_bom"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
            records.action_force_rebuild_mechanical_parts()
        </field>
    </record>

    <!-- AUTOMATIC SYNC ON UPGRADE: Populates all BoM structures into the management view -->
    <function model="mrp.bom" name="_auto_sync_mechanical_parts"/>
</odoo>
