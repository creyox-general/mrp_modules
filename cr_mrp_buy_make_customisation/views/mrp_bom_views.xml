<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_bom_line_tree_inherit_buy_make" model="ir.ui.view">
        <field name="name">mrp.bom.line.tree.inherit.buy.make</field>
        <field name="model">mrp.bom.line</field>
        <field name="inherit_id" ref="mrp.mrp_bom_line_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="is_buy_make_product" invisible="True"/>
            </xpath>
        </field>
    </record>
</odoo>