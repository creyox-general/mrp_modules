<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Manufacturing Order Form View -->
    <record id="view_mrp_production_form_inherit_critical" model="ir.ui.view">
        <field name="name">mrp.production.form.critical</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">

            <!-- Add critical + branch columns to component lines -->
            <xpath expr="//field[@name='move_raw_ids']/list/field[@name='product_id']" position="after">
                <!-- critical is computed from branch/component link — readonly -->
                <field name="critical" widget="boolean_toggle" readonly="1"/>
                <!-- Branch link: visible so users can see which branch the move belongs to -->
                <field name="mrp_bom_line_branch_id" string="Branch" optional="show"/>
                <!-- Component link: optional column, hidden by default but available -->
                <field name="mrp_bom_line_branch_component_id" string="Branch Component" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>