<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sh_purchase_order_line_tree_view_inherit_custom" model="ir.ui.view">
        <field name="name">purchase.order.line.tree.inherit.custom</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="sh_pol_views.sh_rfq_order_line_tree_view_inherit" />
        <field name="arch" type="xml">
            <xpath expr="//list" position="replace">
                <list string="Purchase Order Lines">
                    <field name="project_id" string="Project name" optional="show"/>
                    <field name="product_id" string="Everest PN"/>
                    <field name="manufacture_internal_ref" string="INTERNAL REF of selected MFG" optional="show"/>
                    <field name="product_uom_qty" string="QTY"/>
                    <field name="branch_id" string="Branch" optional="show"/>
                    <field name="vendor_status_line" string="PO status" optional="show"/>
                    <field name="po_type" string="Po type" optional="show"/>
                    <field name="date_planned" string="Expected arrival" optional="show"/>
                    <field name="partner_id" string="Vendor" optional="show"/>
                    <field name="price_unit" string="Cost" optional="show"/>
                    <field name="currency_id" string="Currency" optional="show"/>
                    <field name="sh_pol_image" widget="image" string="Image" options='{"size": [40, 40]}' optional="show"/>
                    <field name="display_date_po" string="Display date of PO" optional="show"/>
                    <field name="buyer_po" string="Buyer" widget="many2one_avatar_user" optional="show"/>
                    <field name="product_document_count" string="Link to document product" optional="show"/>
                    <field name="categ_id" string="Product cat" optional="show"/>
                    <field name="extra_qty" string="Extra qty" optional="show"/>
                    <field name="create_date" string="Created date" optional="show"/>
                    
                    <button class="btn btn-primary" name="action_get_quotation" type="object" icon="fa-eye" title="Quotation" />
                </list>
            </xpath>
        </field>
    </record>

    <record id="sh_pol_purchase_order_line_search_view_inherit_custom" model="ir.ui.view">
        <field name="name">purchase.order.line.search.inherit.custom</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="sh_pol_views.sh_purchase_order_line_search_view_inherit" />
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
<!--                <filter string="Product" name="group_by_product" domain="[]" context="{'group_by': 'product_id'}"/>-->
<!--                <filter string="Vendor" name="group_by_partner" domain="[]" context="{'group_by': 'partner_id'}"/>-->
                <filter string="Buyer" name="group_by_buyer" domain="[]" context="{'group_by': 'buyer_po'}"/>
                <filter string="Product Category" name="group_by_category" domain="[]" context="{'group_by': 'categ_id'}"/>
                <filter string="Status PO" name="group_by_status" domain="[]" context="{'group_by': 'vendor_status_line'}"/>
            </xpath>
        </field>
    </record>
    
    <record id="action_merge_lines_server" model="ir.actions.server">
        <field name="name">Merge Lines</field>
        <field name="model_id" ref="purchase.model_purchase_order_line"/>
        <field name="binding_model_id" ref="purchase.model_purchase_order_line"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                action = records.action_merge_lines()
        </field>
    </record>
</odoo>
